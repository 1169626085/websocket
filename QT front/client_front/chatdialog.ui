  <property name="styleSheet">
   <string notr="true">QWidget#ChatDialog {
    background: #f4f6f8;
    color: #1d2733;
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, sans-serif;
}

QFrame#sideBar {
    background: #233142;
    border: none;
}

QToolButton#avatarButton {
    border: none;
    border-radius: 20px;
    background: #f2c94c;
    color: #233142;
    font-weight: 700;
}

QToolButton#chatToolButton,
QToolButton#contactsToolButton,
QToolButton#addToolButton,
QToolButton#settingsToolButton,
QToolButton#infoButton {
    border: none;
    border-radius: 8px;
    padding: 8px;
    color: #d7e2ec;
    background: transparent;
}

QToolButton#chatToolButton:hover,
QToolButton#contactsToolButton:hover,
QToolButton#addToolButton:hover,
QToolButton#settingsToolButton:hover,
QToolButton#infoButton:hover {
    background: rgba(255, 255, 255, 0.12);
}

QFrame#conversationPanel {
    background: #ffffff;
    border-right: 1px solid #dde5ee;
}

QLineEdit#searchLineEdit {
    min-height: 34px;
    border: 1px solid #d8e1ea;
    border-radius: 7px;
    padding: 0 12px;
    background: #f8fafc;
}

QPushButton#newChatButton,
QPushButton#receiveButton,
QPushButton#sendButton {
    min-height: 34px;
    border: none;
    border-radius: 7px;
    padding: 0 16px;
    font-weight: 600;
}

QPushButton#newChatButton {
    color: #ffffff;
    background: #2f80ed;
}

QPushButton#receiveButton {
    color: #33506d;
    background: #e7edf5;
}

QPushButton#sendButton {
    color: #ffffff;
    background: #24a148;
}

QPushButton#newChatButton:hover {
    background: #256fd1;
}

QPushButton#sendButton:hover {
    background: #1f8f3f;
}

QPushButton#receiveButton:hover {
    background: #dbe5f0;
}

QListWidget#conversationList,
QListWidget#contactList {
    background: transparent;
    border: none;
    outline: none;
}

QListWidget#conversationList::item,
QListWidget#contactList::item {
    border-radius: 8px;
    margin: 3px 8px;
    padding: 4px;
}

QListWidget#conversationList::item:selected,
QListWidget#contactList::item:selected {
    background: #eaf3ff;
}

QLabel#panelTitleLabel,
QLabel#friendsTitleLabel {
    color: #708090;
    font-size: 12px;
    font-weight: 700;
}

QFrame#chatArea {
    background: #f4f6f8;
}

QFrame#chatHeader {
    background: #ffffff;
    border-bottom: 1px solid #dde5ee;
}

QLabel#chatTitleLabel {
    font-size: 20px;
    font-weight: 700;
    color: #1d2733;
}

QLabel#chatSubTitleLabel {
    color: #708090;
}

QScrollArea#messageScrollArea {
    border: none;
    background: #f4f6f8;
}

QWidget#messageScrollContent {
    background: #f4f6f8;
}

QFrame#composerFrame {
    background: #ffffff;
    border-top: 1px solid #dde5ee;
}

QTextEdit#messageEdit {
    border: 1px solid #d8e1ea;
    border-radius: 8px;
    padding: 8px;
    background: #fbfcfe;
}

QToolButton#emojiButton,
QToolButton#imageButton,
QToolButton#fileButton {
    border: none;
    border-radius: 7px;
    padding: 6px 8px;
    color: #52657a;
    background: transparent;
}

QToolButton#emojiButton:hover,
QToolButton#imageButton:hover,
QToolButton#fileButton:hover {
    background: #edf3f9;
}</string>
