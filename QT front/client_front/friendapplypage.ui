  <property name="styleSheet">
   <string notr="true">QWidget#FriendApplyPage {
    background: #f5f7fb;
    color: #1d2733;
    font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, sans-serif;
}

QFrame#applyPanel,
QFrame#requestPanel {
    background: #ffffff;
    border: 1px solid #dde5ee;
    border-radius: 8px;
}

QLabel#titleLabel {
    font-size: 22px;
    font-weight: 700;
}

QLabel#sectionLabel,
QLabel#requestTitleLabel {
    font-size: 14px;
    font-weight: 700;
    color: #334155;
}

QLineEdit#accountLineEdit,
QTextEdit#noteTextEdit {
    border: 1px solid #d8e1ea;
    border-radius: 7px;
    background: #fbfcfe;
    padding: 8px;
}

QPushButton#sendApplyButton {
    min-height: 36px;
    border: none;
    border-radius: 7px;
    padding: 0 18px;
    color: white;
    font-weight: 600;
    background: #2f80ed;
}

QPushButton#closeButton {
    min-height: 34px;
    border: none;
    border-radius: 7px;
    padding: 0 18px;
    color: #33506d;
    font-weight: 600;
    background: #e7edf5;
}

QPushButton#sendApplyButton:hover {
    background: #256fd1;
}

QPushButton#closeButton:hover {
    background: #dbe5f0;
}

QListWidget#requestList {
    border: none;
    background: transparent;
    outline: none;
}

QListWidget#requestList::item {
    min-height: 42px;
    border-radius: 7px;
    padding: 8px;
}

QListWidget#requestList::item:selected {
    background: #eaf3ff;
}</string>
